  QKatalogPRICE_CALC.AsCurrency:=QKatalogPRICE_USD.AsCurrency * KURSUSD;
end;

procedure TDMod.Refresh_Qkatalog;
var
  R:Integer;
begin
R:=PagesDlg.Grid_Kat.DataSource.DataSet.FieldByName('NN').AsInteger;
DMod.QKatalog.Close;
DMod.QKatalog.Open;
if not DMod.QKatalog.Locate('NN',R,[]) then DMod.QKatalog.Locate('NN',R+1,[]);
end;

procedure TDMod.Refresh_RegTi;
var
  R:Integer;
begin
R:=Dmod.Qry_RegTi.FieldByName('ID').AsInteger;
DMod.Qry_RegTi.Close;
DMod.Qry_RegTi.Open;
DMod.Qry_RegTi.Locate('ID',R,[]);
end;

procedure TDMod.Refresh_Settings;
