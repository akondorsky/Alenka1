procedure TDMod.T_KursValNewRecord(DataSet: TDataSet);
var
 qry:TIBQuery;
begin
  qry := TIBQuery.Create(Self);
  try
    qry.Database:=DB;
    qry.SQL.Add('select gen_id(gen_id_kursval,1) from rdb$database');
    qry.Open;
    T_KursValID_NUM.AsInteger:=qry.Fields[0].AsInteger;
  finally
    qry.Free;
  end;
end;

procedure TDMod.DModCreate(Sender: TObject);
 var
  F:TextFile;
  FileName:String;
begin
  FileName:='connectstring.ini';
  AssignFile(F,FileName);
  Reset(F);
  ReadLn(F,DB_Name);  // ÷čňŕĺě ďóňü ę ôŕéëó ÁÄ
  ReadLn(F,DB_Description);  // ÷čňŕĺě îďčńŕíčĺ ÁÄ
  ReadLn(F,CASH_PORT);  // COM-port KKM
  Readln(F,RunMode);  //  ďđîâĺđ˙ĺě đĺćčě çŕďóńęŕ äë˙ ńĺđâčńŕ
  CloseFile(F);
  _ConnectionFlag:=ConnectToDatabase;
end;

procedure TDMod.Closedatabases;
begin
Db.CloseDataSets;
Db.Close;
end;

function TDMod.ConnectToDatabase: Boolean;
var
  F:TextFile;
  DB_Name,FileName:String;
begin
  Result:=False;
  FileName:='connectstring.ini';
  AssignFile(F,FileName);
  Reset(F);
  ReadLn(F,DB_Name);
//  ReadLn(F,RemoteFlag);
  CloseFile(F);
 if DB.Connected then DB.Close;
// ShowMessage('Is connected');
 DB.DatabaseName:='';
 DB.DatabaseName:=Trim(Db_Name);
// ShowMessage('Set db_name');
 try
  DB.Open;
  OpenDatabases;
 except
   on E:Exception do
    begin
       ShowMessage(E.Message);
       halt;
    end;
 end;
 Result:=DB.Connected;
end;

