procedure Atoll_On;
var
 r:Integer;
begin
{  atol25f.PortNumber:=CASH_PORT;
  atol25f.BaudRate:=18;
  atol25f.UseAccessPassword:=True;
  atol25f.WriteLogFile:=0;
