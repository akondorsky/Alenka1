  ShowKKMCondition;}
  r:=-9999;
  atol25f.PortNumber:=CASH_PORT;
  r:=atol25f.GetStatus;
  atol25f.BaudRate:=18;
  r:=atol25f.GetStatus;
  atol25f.Model:=61; //atol 30-f
