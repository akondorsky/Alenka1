  id:Integer;
begin
  if DMod.Qry_Shippers.Active then DMod.Qry_Shippers.Close;
  DMod.Qry_Shippers.SQL.Clear;
  if Dmod.Qry_RepZak.Active then  Dmod.Qry_RepZak.Close;
