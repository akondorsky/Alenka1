function TPagesDlg.DelLastSymbol(Text, S: String): String;
var
 p,l:Integer;
 tmp:String;
begin
  Result:=Text;
  tmp:=ReverseString(Trim(Text));
  p:=Pos(S,tmp);
  if p = 1 then
    begin
      l:=Length(tmp);
      tmp:=Copy(tmp,2,l-1);
      Result:=ReverseString(tmp);
    end;
end;

